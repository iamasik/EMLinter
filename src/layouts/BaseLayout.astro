---
import '../styles/global.css';
import AnnouncementBar from '../components/layout/AnnouncementBar';
import Header from '../components/layout/Header';
import Footer from '../components/layout/Footer';
import Breadcrumbs from '../components/layout/Breadcrumbs';
import CookieConsent from '../components/CookieConsent.astro';

export interface Props {
    title: string;
    description: string;
    keywords?: string;
    ogImage?: string;
    /** Explicit OG image dimensions. Only pass when known — omit for Firestore
     *  thumbnails of unknown size so we don't emit misleading width/height. */
    ogImageWidth?: number;
    ogImageHeight?: number;
    ogType?: 'website' | 'article';
    /** ISO 8601 timestamps for article OG tags (only emitted when ogType==='article'). */
    publishedTime?: string;
    modifiedTime?: string;
    canonical?: string;
    noindex?: boolean;
    /** Optional JSON-LD schema(s) injected before </head>. Pass an object or an array of objects. */
    jsonLd?: object | object[];
    /** Optional FAQ list — when provided, FAQPage schema is automatically emitted. */
    faqSchema?: { question: string; answer: string }[];
}

const SITE_URL = 'https://www.emlinter.com';
const SITE_NAME = 'EMLinter';
const DEFAULT_OG = `${SITE_URL}/og-default.png`;

const {
    title,
    description,
    keywords,
    ogImage = DEFAULT_OG,
    ogImageWidth,
    ogImageHeight,
    ogType = 'website',
    publishedTime,
    modifiedTime,
    canonical,
    noindex = false,
    jsonLd,
    faqSchema,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = canonical ?? `${SITE_URL}${currentPath === '/' ? '' : currentPath.replace(/\/$/, '')}`;

// Only emit og:image dimensions when we actually know them: the branded default
// is a fixed 1200×630; a caller-supplied image reports dims only if explicitly
// passed (Firestore thumbnails are unknown size, so they omit these tags).
const ogW = ogImage === DEFAULT_OG ? 1200 : ogImageWidth;
const ogH = ogImage === DEFAULT_OG ? 630 : ogImageHeight;

const baseOrganization = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE_NAME,
    url: SITE_URL,
    // Raster ≥112×112 for Google's logo rich result (SVG is not eligible).
    logo: `${SITE_URL}/icon-512.png`,
    // `sameAs` intentionally omitted until real, verified social profiles exist —
    // linking to unverified/placeholder handles is a weak or misleading entity signal.
};

const baseWebsite = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: SITE_URL,
    description: 'Free HTML email editor, linter, minifier, dark-mode tester, and bulletproof Outlook generators.',
    potentialAction: {
        '@type': 'SearchAction',
        target: `${SITE_URL}/templates?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
    },
};

const userLd: object[] = jsonLd
    ? Array.isArray(jsonLd) ? jsonLd : [jsonLd]
    : [];

// BreadcrumbList schema, auto-derived from the URL path (server-rendered so it is
// crawlable in the initial HTML). Home is always the first crumb.
const humanize = (seg: string) =>
    decodeURIComponent(seg)
        .replace(/-/g, ' ')
        .replace(/\b\w/g, (c) => c.toUpperCase());

const segments = currentPath.split('/').filter(Boolean);
const breadcrumbLd = segments.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
            ...segments.map((seg, i) => ({
                '@type': 'ListItem',
                position: i + 2,
                name: humanize(seg),
                item: `${SITE_URL}/${segments.slice(0, i + 1).join('/')}`,
            })),
        ],
    }]
    : [];

const faqLd = faqSchema && faqSchema.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqSchema.map(({ question, answer }) => ({
            '@type': 'Question',
            name: question,
            acceptedAnswer: { '@type': 'Answer', text: answer },
        })),
    }]
    : [];

const allLd = [baseOrganization, baseWebsite, ...breadcrumbLd, ...userLd, ...faqLd];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- Google Analytics — consent-gated (GDPR). gtag.js is NOT requested until the
             visitor accepts cookies; the loader is defined here and invoked either
             immediately (if consent was already granted) or by the CookieConsent banner. -->
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.__loadGA = function () {
                if (window.__gaLoaded) return;
                window.__gaLoaded = true;
                var s = document.createElement('script');
                s.async = true;
                s.src = 'https://www.googletagmanager.com/gtag/js?id=G-3CD8LYSFCQ';
                document.head.appendChild(s);
                gtag('js', new Date());
                gtag('config', 'G-3CD8LYSFCQ');
            };
            try {
                if (localStorage.getItem('emlinter-cookie-consent') === 'granted') {
                    window.__loadGA();
                }
            } catch (e) {}
        </script>

        <!-- Icons -->
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="canonical" href={canonicalUrl} />

        <title>{title}</title>
        <meta name="description" content={description} />
        {keywords && <meta name="keywords" content={keywords} />}
        <meta name="author" content="EMLinter" />
        <meta name="generator" content="Astro" />
        <meta name="theme-color" content="#0e1126" />
        {noindex
            ? <meta name="robots" content="noindex, nofollow" />
            : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        }

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImage} />
        {ogW && <meta property="og:image:width" content={String(ogW)} />}
        {ogH && <meta property="og:image:height" content={String(ogH)} />}
        <meta property="og:locale" content="en_US" />
        {ogType === 'article' && publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
        )}
        {ogType === 'article' && modifiedTime && (
            <meta property="article:modified_time" content={modifiedTime} />
        )}

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        {/* twitter:site/creator omitted until a verified @handle exists — a placeholder
            handle produces a broken/misattributed card. */}

        {/* Fonts (Inter body + Space Grotesk headings) are self-hosted and declared
            in the render-blocking global.css @font-face rules with font-display:swap,
            so the browser discovers and fetches them early on its own. We deliberately
            do NOT add <link rel="preload"> for them: on fast/cached loads Chrome flags
            the preload as "not used within a few seconds from the window's load event"
            (a benign but noisy warning), and the manual preload also risks a duplicate
            fetch. The @font-face swap path already renders text without blocking. */}

        <!-- Preconnect -->
        <link rel="preconnect" href="https://firestore.googleapis.com" />

        <!-- Structured data -->
        {allLd.map((schema) => (
            <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        ))}
    </head>
    <body class="min-h-screen flex flex-col overflow-x-hidden">
        <AnnouncementBar client:only="react" />
        <!-- Header, Breadcrumbs, Footer use client:load (not client:only) so their nav
             and link markup is server-rendered into the initial HTML — a crawlable
             internal-link graph for non-JS crawlers — then hydrated for interactivity
             (dropdowns, mobile menu, newsletter/policy modals). All three are SSR-safe:
             browser APIs are used only inside effects/handlers, never at render. -->
        <Header currentPath={currentPath} client:load />
        <main class="container-wide py-8 md:py-12 flex-grow w-full">
            <Breadcrumbs currentPath={currentPath} client:load />
            <slot />
        </main>
        <Footer client:load />
        <CookieConsent />
    </body>
</html>
