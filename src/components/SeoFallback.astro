---
/**
 * Server-rendered, crawlable fallback content for `client:only` React pages.
 *
 * Passed via `slot="fallback"` to a `client:only` island: Astro renders this
 * markup into the initial HTML (so non-JS crawlers — Bing, social scrapers, AI
 * bots — see a real <h1>, intro copy, and internal links) and automatically
 * removes it the moment the React component hydrates. No client-side hide hack.
 *
 * Mirrors PageHero.tsx styling (grid backdrop, chip, pill links) so the brief
 * pre-hydration window reads as an intentional, branded hero rather than a
 * half-loaded page. Astro removes it the instant React mounts.
 */
export interface Props {
    heading: string;
    intro: string;
    links?: { href: string; label: string }[];
}

const { heading, intro, links = [] } = Astro.props;
---
<section class="relative text-center pt-6 md:pt-10 pb-10 md:pb-14" data-seo-fallback>
    <div class="absolute inset-0 -z-10 bg-grid-fade pointer-events-none"></div>
    <div class="flex justify-center">
        <span class="chip text-brand-300 border-brand-400/30 bg-brand-500/10 mb-5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
            Loading toolkit…
        </span>
    </div>
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-balance mx-auto max-w-4xl">
        {heading}
    </h1>
    <p class="mt-5 text-base md:text-lg text-ink-300 text-pretty mx-auto max-w-2xl">
        {intro}
    </p>
    {links.length > 0 && (
        <nav class="mt-8 flex flex-wrap gap-3 justify-center" aria-label="Related pages">
            {links.map((link) => (
                <a href={link.href} class="btn-secondary text-sm py-2 px-4">
                    {link.label}
                </a>
            ))}
        </nav>
    )}
</section>
