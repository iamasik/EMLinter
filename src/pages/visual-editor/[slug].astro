---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import VisualEditorPage from '../../components/pages/VisualEditorPage';

const { slug } = Astro.params;
---
<!-- Deep-link into the editor with a template preloaded. Canonical points at the
     base editor URL so these functional variants don't compete as duplicate content. -->
<BaseLayout
  title="Visual HTML Email Editor — Drag & Drop, No Code | EMLinter"
  description="Edit responsive HTML email templates visually in your browser. Drag, drop, and export production-ready code for Gmail, Outlook, and Apple Mail."
  canonical="https://www.emlinter.com/visual-editor"
>
  <VisualEditorPage slug={slug} client:only="react" />
</BaseLayout>
