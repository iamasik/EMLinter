# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Firebase web config. These are public identifiers (the Firebase SDK ships them to the
# browser) — NOT secrets. Access control is enforced by Firestore Security Rules, not by
# hiding these. PUBLIC_-prefixed so they are available client-side and in server-side
# detail shells / sitemap.xml.ts.
PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# hCaptcha (spam protection on the contact form). Get these from https://dashboard.hcaptcha.com.
# The sitekey is public (rendered in the browser widget), so it is PUBLIC_-prefixed. The secret
# is server-only — used by /api/contact to call the siteverify endpoint. Do NOT prefix it with
# PUBLIC_, or Astro would expose it in the client bundle.
PUBLIC_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
HCAPTCHA_SECRET=your-hcaptcha-secret

# Firebase Admin SDK (server-only). Used by src/services/firebaseAdmin.ts for the writes
# that used to go through the public client SDK (contact form, template ratings, post
# votes) — those are now server-gated and firestore.rules denies all client writes.
# Generate: Firebase console -> Project settings -> Service accounts -> Generate new
# private key. Paste the ENTIRE downloaded JSON file contents as a single-line value
# here. Do NOT prefix with PUBLIC_ — this must never reach the browser bundle.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
