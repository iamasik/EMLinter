---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPage from '../../../components/pages/BlogPage';
import SeoFallback from '../../../components/SeoFallback.astro';
---
<BaseLayout title="HTML Email Development Blog & Tips | EMLinter" description="Tutorials, tips & insights on HTML email development — coding bulletproof Outlook layouts, dark mode, deliverability, and responsive design best practices.">
  <BlogPage client:only="react">
    <SeoFallback
      slot="fallback"
      heading="EMLinter Blog"
      intro="Insights, tutorials, and updates on HTML email development from the EMLinter team."
      links={[
        { href: '/tools', label: 'Developer Tools' },
        { href: '/solutions', label: 'Outlook Solutions' },
        { href: '/templates', label: 'Email Templates' },
      ]}
    />
  </BlogPage>
</BaseLayout>
