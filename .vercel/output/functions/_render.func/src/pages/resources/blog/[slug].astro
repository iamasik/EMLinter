---
export const prerender = false;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostPage from '../../../components/pages/BlogPostPage';
import SeoFallback from '../../../components/SeoFallback.astro';
import { getPostBySlug } from '../../../services/firebase';

const { slug } = Astro.params;
const SITE_URL = 'https://emlinter.com';
const canonicalUrl = `${SITE_URL}${Astro.url.pathname.replace(/\/$/, '')}`;

// Fetch server-side so crawlers get real per-post title, description, OG + article schema
// in the initial HTML (the body still hydrates client-side via the React component).
let post = null;
try {
  post = await getPostBySlug(slug!);
} catch (e) {
  console.error('Blog SSR meta fetch failed:', e);
}

const title = post ? `${post.title} | EMLinter` : 'Blog Post | EMLinter';
const description = post?.seoMetaDescription
  || 'Read this article on HTML email development, deliverability, and design.';
const ogImage = post?.thumbnailUrl || undefined;
const fbHeading = post?.title || 'HTML Email Development Article';
const fbIntro = post?.seoMetaDescription
  || 'Read this article on HTML email development, deliverability, and design — practical tips for coding bulletproof, responsive campaigns that render everywhere.';

let toIso = (v: any) => { try { return v?.toDate?.().toISOString(); } catch { return undefined; } };
const jsonLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
      headline: post.title,
      description: post.seoMetaDescription,
      image: post.thumbnailUrl || `${SITE_URL}/og-default.png`,
      author: { '@type': 'Person', name: post.author },
      publisher: {
        '@type': 'Organization',
        name: 'EMLinter',
        logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` },
      },
      datePublished: toIso(post.createdAt),
      dateModified: toIso(post.createdAt),
      keywords: post.tags?.join(', '),
    }
  : undefined;
---
<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <BlogPostPage slug={slug!} client:only="react">
    <SeoFallback
      slot="fallback"
      heading={fbHeading}
      intro={fbIntro}
      links={[
        { href: '/resources/blog', label: 'All Blog Posts' },
        { href: '/tools', label: 'Developer Tools' },
        { href: '/templates', label: 'Email Templates' },
      ]}
    />
  </BlogPostPage>
</BaseLayout>
