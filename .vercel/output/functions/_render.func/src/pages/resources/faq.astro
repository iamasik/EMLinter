---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqPage from '../../components/pages/OurExpertsPage';
import SeoFallback from '../../components/SeoFallback.astro';
---
<BaseLayout title="FAQ & Support — HTML Email Help | EMLinter" description="Answers to common questions about EMLinter's free HTML email tools — the linter, minifier, dark-mode tester, Outlook generators, templates, and privacy.">
  <FaqPage client:only="react">
    <SeoFallback
      slot="fallback"
      heading="Frequently Asked Questions"
      intro="Find answers to common questions about our tools and services."
      links={[
        { href: '/tools', label: 'Developer Tools' },
        { href: '/resources/how-it-works', label: 'How It Works' },
        { href: '/contact-us', label: 'Contact Us' },
      ]}
    />
  </FaqPage>
</BaseLayout>
