---
import BaseLayout from '../layouts/BaseLayout.astro';

// Static, server-rendered content (no client:only) so the 404 is useful even without JS.
const links = [
  { href: '/templates', label: 'Email Templates' },
  { href: '/tools', label: 'Developer Tools' },
  { href: '/solutions', label: 'Outlook Solutions' },
  { href: '/visual-editor', label: 'Visual Editor' },
  { href: '/resources/blog', label: 'Blog' },
  { href: '/contact-us', label: 'Contact Us' },
];
---
<BaseLayout
  title="Page Not Found (404) | EMLinter"
  description="The page you're looking for doesn't exist. Explore EMLinter's free HTML email tools, templates, and guides instead."
  noindex={true}
>
  <section class="text-center py-16 md:py-24">
    <p class="gradient-text font-display text-7xl md:text-8xl font-extrabold">404</p>
    <h1 class="mt-4 text-3xl md:text-4xl font-display font-bold text-gray-50">
      This page took a wrong turn
    </h1>
    <p class="mt-4 max-w-xl mx-auto text-gray-400">
      The page you're looking for doesn't exist or may have moved. Try one of these
      instead, or head back to the homepage.
    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {links.map((l) => (
        <a href={l.href} class="chip hover:text-pink-300 transition-colors">{l.label}</a>
      ))}
    </div>

    <div class="mt-10">
      <a href="/" class="btn-primary inline-block">Back to Homepage</a>
    </div>
  </section>
</BaseLayout>
